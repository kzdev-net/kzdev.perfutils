<Project>
  <!-- 
    Import the next higher level Directory.Packages.props file. 
   -->
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Packages.props', '$(MSBuildThisFileDirectory)..\'))" />
  <!-- 
    Define test project package version properties
   -->
  <ItemGroup Label="TestPackageVersions">
    <PackageVersion Include="Bogus" Version="35.6.4" />
    <PackageVersion Include="coverlet.collector" Version="6.0.4" />
    <PackageVersion Include="FluentAssertions" Version="8.7.1" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="XunitXml.TestLogger" Version="7.0.2" />
  </ItemGroup>
  <ItemGroup Label="TestRunnerPackageVersions">
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageVersion Include="xunit.v3" Version="3.1.0" />
    <PackageVersion Include="xunit.v3.extensibility.core" Version="3.1.0" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>
</Project>